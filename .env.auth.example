# Copy this file to .env before running docker-compose.auth.yml.
# .env is gitignored and must never be committed.

# Postgres / TimescaleDB
POSTGRES_DB=lucid
POSTGRES_USER=lucid
POSTGRES_PASSWORD=CHANGE_ME

# EMQX dashboard + provisioner API login
EMQX_API_USERNAME=lucid
EMQX_API_PASSWORD=CHANGE_ME

# Central Command MQTT credentials stored by lucid-auth
LUCID_MQTT_USERNAME=central-command
LUCID_MQTT_PASSWORD=CHANGE_ME

# LDAP authenticator for EMQX
LDAP_SERVER=ldap.example.com:389
LDAP_BIND_USERNAME=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=CHANGE_ME
LDAP_BASE_DN=ou=users,dc=example,dc=com
LDAP_FILTER=
