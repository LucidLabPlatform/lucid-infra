# Copy this file to .env and fill in all CHANGE_ME values before deploying.
# .env is gitignored and must never be committed to git.
#
# Generate a strong SESSION_SECRET with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Postgres
POSTGRES_DB=lucid
POSTGRES_USER=lucid
POSTGRES_PASSWORD=CHANGE_ME

# EMQX dashboard + API
EMQX_API_USERNAME=lucid
EMQX_API_PASSWORD=CHANGE_ME

# Central Command MQTT credentials
LUCID_MQTT_USERNAME=central-command
LUCID_MQTT_PASSWORD=CHANGE_ME

# LDAP authenticator for EMQX
LDAP_SERVER=ldap.example.com:389
LDAP_BIND_USERNAME=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=CHANGE_ME
LDAP_BASE_DN=ou=users,dc=example,dc=com
LDAP_FILTER=

# lucid-ui
DASHBOARD_PASSWORD=CHANGE_ME
SESSION_SECRET=CHANGE_ME

# Ollama model (optional override)
OLLAMA_MODEL=llama3.1:8b
