# =============================================================================
# LUCID Infrastructure — Environment Variables
# =============================================================================
# Copy this file to .env and fill in ALL values before deploying.
# .env is gitignored and must never be committed.
#
# This is the ONLY .env file needed — all services read from here.
# If a variable is missing, the service will fail to start.
# =============================================================================

# -- Postgres / TimescaleDB ---------------------------------------------------
POSTGRES_DB=lucid
POSTGRES_USER=lucid
POSTGRES_PASSWORD=

# -- EMQX dashboard + management API ------------------------------------------
EMQX_API_USERNAME=lucid
EMQX_API_PASSWORD=

# -- Central Command MQTT credentials -----------------------------------------
LUCID_MQTT_USERNAME=central-command
LUCID_MQTT_PASSWORD=

# -- lucid-ui ------------------------------------------------------------------
DASHBOARD_PASSWORD=
SESSION_SECRET=

# -- Ollama (AI service) -------------------------------------------------------
OLLAMA_MODEL=llama3.1:8b

# -- Optional: LDAP authentication for EMQX -----------------------------------
# Leave blank or remove to disable LDAP. When LDAP_SERVER is empty,
# the EMQX entrypoint automatically strips the LDAP authenticator.
LDAP_SERVER=
LDAP_BIND_USERNAME=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_FILTER=
